{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "types": ["node"],
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "composite": false
  },
  "include": ["src/**/*", "script/**/*.ts", "cli/**/*.ts", "deployments/**/*.json", "tsup.config.ts"],
  "exclude": ["dist", "contracts", "lib", "out", "test"]
}
