{
  "name": "@tare-io/tare-contracts",
  "version": "0.5.23",
  "description": "Smart contracts, ABIs, and TypeScript bindings for Tare protocol",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./enums": {
      "types": "./dist/enums.d.ts",
      "import": "./dist/enums.mjs",
      "require": "./dist/enums.js"
    },
    "./deployments": {
      "types": "./dist/deployments.d.ts",
      "import": "./dist/deployments.mjs",
      "require": "./dist/deployments.js"
    },
    "./abis": {
      "types": "./dist/abis.d.ts",
      "import": "./dist/abis.mjs",
      "require": "./dist/abis.js"
    },
    "./anvil": {
      "types": "./dist/anvil.d.ts",
      "import": "./dist/anvil.mjs",
      "require": "./dist/anvil.js"
    }
  },
  "bin": {
    "tare-contracts": "dist/bin/cli.mjs"
  },
  "files": [
    "dist",
    "contracts",
    "lib",
    "script",
    "cli",
    "state",
    "test/lib",
    "foundry.toml",
    "remappings.txt"
  ],
  "publishConfig": {
    "@tare-io:registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "prepare:submodules": "git submodule update --init --recursive",
    "extract-enums": "tsx cli/index.ts extract-enums",
    "generate:abis": "wagmi generate",
    "generate:deployments": "tsx cli/index.ts generate-deployments",
    "codegen": "pnpm extract-enums && pnpm generate:abis && pnpm generate:deployments",
    "build:forge": "forge build",
    "tsup": "tsup",
    "prebuild": "pnpm build:forge",
    "build": "pnpm bake:anvil-state && pnpm codegen && pnpm tsup",
    "pretest": "pnpm build:forge",
    "test": "forge test",
    "test:cli": "node --import tsx --test cli/test/*.test.ts",
    "prepublishOnly": "pnpm build",
    "typecheck": "pnpm codegen && tsc --noEmit",
    "bake:anvil-state": "tsx cli/bake-anvil-state.ts",
    "tare-contracts": "tsx cli/index.ts",
    "deploy:local": "ENV=testing tsx cli/index.ts deploy local"
  },
  "keywords": [
    "tare",
    "ethereum",
    "smart-contracts",
    "abi",
    "wagmi",
    "viem"
  ],
  "author": "",
  "license": "BUSL-1.1",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@wagmi/cli": "^2.6.0",
    "chalk": "^5.6.2",
    "dotenv-cli": "^11.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@solidity-parser/parser": "^0.20.2",
    "@wagmi/core": "^2.22.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "viem": "^2.38.0"
  },
  "peerDependencies": {
    "@wagmi/core": "^2.22.0",
    "viem": "^2.38.0"
  }
}
